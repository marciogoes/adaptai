# ===============================================
# ADAPTAI - EXEMPLO DE CONFIGURAÇÃO
# ===============================================
# Copie este arquivo para .env e preencha os valores

# ==========================================
# DATABASE - MySQL
# ==========================================
DB_HOST=seu-host.mysql.dbaas.com.br
DB_PORT=3306
DB_USER=seu_usuario
DB_PASSWORD=sua_senha_super_segura
DB_NAME=teamarcionovo

# ==========================================
# ANTHROPIC API (IA)
# ==========================================
# Obtenha sua API key em: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-...

# ==========================================
# JWT / AUTENTICAÇÃO
# ==========================================
# Gere uma chave secreta forte: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=sua-chave-secreta-super-forte-aqui-64-caracteres-minimo
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ==========================================
# CORS - URLs PERMITIDAS
# ==========================================
# Em desenvolvimento
FRONTEND_URL=http://localhost:5173

# Em produção (adicione todos os domínios necessários)
# FRONTEND_URL=https://seu-dominio.com,https://www.seu-dominio.com

# ==========================================
# AMBIENTE
# ==========================================
ENVIRONMENT=development  # development, staging, production

# ==========================================
# LOGS
# ==========================================
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL

# ==========================================
# FILE STORAGE
# ==========================================
STORAGE_PATH=./storage
MAX_FILE_SIZE_MB=50

# ==========================================
# RATE LIMITING (Opcional - para produção)
# ==========================================
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_PER_MINUTE=60

# ==========================================
# REDIS (Opcional - para cache em produção)
# ==========================================
# REDIS_URL=redis://localhost:6379
# REDIS_PASSWORD=sua_senha_redis

# ==========================================
# SENTRY (Opcional - para monitoring)
# ==========================================
# SENTRY_DSN=https://...@sentry.io/...
# SENTRY_ENVIRONMENT=production

# ==========================================
# NOTAS IMPORTANTES
# ==========================================
# 1. NUNCA commite o arquivo .env no Git!
# 2. Use senhas fortes em produção
# 3. Mantenha SECRET_KEY seguro e único por ambiente
# 4. Configure CORS corretamente para segurança
# 5. Use HTTPS em produção
